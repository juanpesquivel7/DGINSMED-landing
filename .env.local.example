# Copiar este archivo a .env.local y completar con las claves reales.

# Clave de API de Envia.com (ver panel de tu cuenta en envia.com)
ENVIA_API_KEY=

# "production" para usar api.envia.com, cualquier otro valor usa el sandbox api-test.envia.com
ENVIA_API_ENV=sandbox

# Access token de Mercado Pago (Checkout Pro)
MERCADOPAGO_ACCESS_TOKEN=

# URL pública del sitio (usada para las back_urls de Mercado Pago)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API key de Resend (resend.com) para el mail de aviso de nuevo pedido
RESEND_API_KEY=

# Mail donde llega el aviso de "nuevo pedido pago"
ORDER_NOTIFICATION_EMAIL=

# Remitente del mail de aviso (opcional; por defecto usa el sandbox de Resend)
RESEND_FROM_EMAIL=DG-INSMED <onboarding@resend.dev>
